{
  "$id": "mbse-pipeline/requirement-schema/schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Main Schema",
  "type": "object",
  "properties": {
    "requirements": {
      "type": "array",
      "items": {
        "title": "Requirement",
        "type": "object",
        "properties": {
          "requirementId": {
            "type": "string",
            "pattern": "^REQ-.*"
          },
          "cameoUUID": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "requirementType": {
            "type": "string",
            "enum": [
              "Functional", "Design Constraint", "Performance", "Interface"
            ]
          },
          "status": {
            "type": "string"
          },
          "parentRequirementId": {
            "type": "string"
          },
          "verificationCriteria": {
            "type": "array",
            "items": {
              "title": "Verification",
              "type": "object",
              "properties": {
                "verificationId": {
                  "type": "string",
                  "pattern": "^VC-.*"
                },
                "verificationCriteriaName": {
                  "type": "string"
                },
                "verificationDescription": {
                  "type": "string"
                },
                "verificationMethod": {
                  "type": "string",
                  "enum": ["Test", "Analysis", "Demonstration", "Inspection"]
                },
                "verificationTestData": {
                  "type": "string"
                }
              },
              "required": [
                "verificationId", "verificationCriteriaName", "verificationDescription",
                "verificationMethod"
              ]
            }
          }
        },
        "required": [
          "requirementId", "cameoUUID", "name",
          "description", "requirementType", "status",
          "parentRequirementId", "verificationCriteria"
        ]
      }
    }
  },
  "required": [
    "requirements"
  ]
}
